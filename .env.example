# Application Environment Variables
# Copy this file to .env and update values for your deployment

# ===========================================
# Node.js Environment
# ===========================================

# Environment mode: 'development' or 'production'
NODE_ENV=production

# Server port
PORT=3000

# ===========================================
# Application Information
# ===========================================

# Application version (set during deployment)
APP_VERSION=1.0.0

# Application name
APP_NAME=simple-cicd-app

# ===========================================
# Logging
# ===========================================

# Log level: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# Log format: 'json' or 'text'
LOG_FORMAT=text

# ===========================================
# Security
# ===========================================

# Enable CORS
CORS_ENABLED=true

# CORS origin (for production, set to specific domain)
CORS_ORIGIN=*

# Health check timeout (milliseconds)
HEALTH_CHECK_TIMEOUT=5000

# ===========================================
# Database (if added in future)
# ===========================================

# DATABASE_URL=postgresql://user:password@localhost:5432/app
# DATABASE_POOL_SIZE=20
# DATABASE_TIMEOUT=10000

# ===========================================
# External Services (if added in future)
# ===========================================

# API_KEY=your_api_key_here
# API_ENDPOINT=https://api.example.com

# ===========================================
# Docker-specific
# ===========================================

# Container memory limit (in bytes, for docker stats)
# MEMORY_LIMIT=536870912  # 512MB

# Container CPU limit (for docker compose)
# CPU_LIMIT=0.5

# Auto-restart policy
# RESTART_POLICY=unless-stopped

# ===========================================
# Notes
# ===========================================

# - Never commit actual credentials to the repository
# - Use GitHub Secrets for CI/CD credentials in production
# - Rotate API keys and passwords regularly
# - For production: use environment-specific .env files
# - Consider using AWS Secrets Manager or Azure Key Vault
