pipeline {
  agent any

  options {
    buildDiscarder(logRotator(numToKeepStr: '10'))
    timeout(time: 1, unit: 'HOURS')
    timestamps()
  }

  environment {
    DOCKER_REGISTRY = 'docker.io'
    DOCKER_REGISTRY_CREDENTIALS = credentials('docker-hub-credentials')
    KUBE_CONFIG = credentials('kubeconfig')
    GIT_COMMIT_HASH = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
    BUILD_VERSION = "${BUILD_NUMBER}-${GIT_COMMIT_HASH}"
    BACKEND_IMAGE = "${DOCKER_REGISTRY}/healthsync/backend:${BUILD_VERSION}"
    AUTH_IMAGE = "${DOCKER_REGISTRY}/healthsync/auth:${BUILD_VERSION}"
    FRONTEND_IMAGE = "${DOCKER_REGISTRY}/healthsync/frontend:${BUILD_VERSION}"
  }

  stages {
    stage('Checkout') {
      steps {
        script {
          echo "=== Checking out code ==="
          checkout scm
          sh 'git status'
        }
      }
    }

    stage('Build & Test Backend') {
      steps {
        script {
          echo "=== Building and testing backend ==="
          dir('healthsync/backend') {
            sh 'npm install'
            sh 'npm run test'
            sh '''
              # Run migration and seed (optional for testing)
              # npm run migrate
              # npm run seed
            '''
          }
        }
      }
    }

    stage('Security Scan') {
      steps {
        script {
          echo "=== Running security scans ==="
          dir('healthsync') {
            sh '''
              # Trivy image scanning (if installed)
              # trivy image --severity HIGH,CRITICAL ${BACKEND_IMAGE}
              
              # SonarQube scan (optional)
              # sonar-scanner -Dsonar.projectKey=healthsync
              
              echo "Security scan stage: configured for optional Trivy/SonarQube"
            '''
          }
        }
      }
    }

    stage('Build Docker Images') {
      steps {
        script {
          echo "=== Building Docker images ==="
          sh '''
            cd healthsync
            docker build -t ${BACKEND_IMAGE} ./backend
            docker build -t ${AUTH_IMAGE} ./auth-service
            docker build -t ${FRONTEND_IMAGE} ./frontend
            docker images | grep healthsync
          '''
        }
      }
    }

    stage('Push to Registry') {
      steps {
        script {
          echo "=== Pushing images to Docker Hub ==="
          sh '''
            echo ${DOCKER_REGISTRY_CREDENTIALS_PSW} | docker login -u ${DOCKER_REGISTRY_CREDENTIALS_USR} --password-stdin
            docker push ${BACKEND_IMAGE}
            docker push ${AUTH_IMAGE}
            docker push ${FRONTEND_IMAGE}
            docker logout
          '''
        }
      }
    }

    stage('Deploy to Kubernetes') {
      steps {
        script {
          echo "=== Deploying to Kubernetes ==="
          sh '''
            # Set kubeconfig
            mkdir -p ~/.kube
            cp ${KUBE_CONFIG} ~/.kube/config
            
            # Check cluster connectivity
            kubectl cluster-info
            
            # Apply namespace and configs
            kubectl apply -f healthsync/kubernetes/namespaces/
            kubectl apply -f healthsync/kubernetes/configmaps/
            kubectl apply -f healthsync/kubernetes/secrets/
            
            # Deploy services
            kubectl apply -f healthsync/kubernetes/services/
            kubectl apply -f healthsync/kubernetes/deployments/
            
            # Deploy ingress
            kubectl apply -f healthsync/kubernetes/ingress/
            
            # Deploy HPA
            kubectl apply -f healthsync/kubernetes/deployments/hpa.yaml
            
            # Check rollout status
            kubectl rollout status deployment/backend -n healthsync --timeout=5m
            kubectl rollout status deployment/auth-service -n healthsync --timeout=5m
            kubectl rollout status deployment/frontend -n healthsync --timeout=5m
            
            # Get services
            kubectl get svc -n healthsync
          '''
        }
      }
    }

    stage('Smoke Tests') {
      steps {
        script {
          echo "=== Running smoke tests ==="
          sh '''
            # Get frontend service URL
            FRONTEND_URL=$(kubectl get svc frontend -n healthsync -o jsonpath='{.status.loadBalancer.ingress[0].hostname}')
            
            # Wait for services to be ready
            sleep 10
            
            # Basic health check
            curl -f http://localhost:3001/api/health || true
            curl -f http://localhost:3002/auth/verify -H "Authorization: Bearer test" || true
            
            echo "Smoke tests completed"
          '''
        }
      }
    }

    stage('Notify') {
      steps {
        script {
          echo "=== Build notification ==="
          sh '''
            echo "Build completed: ${BUILD_VERSION}"
            # Send Slack notification (configure as needed)
            # curl -X POST -H 'Content-type: application/json' --data '{"text":"HealthSync deployment ${BUILD_VERSION} completed"}' ${SLACK_WEBHOOK}
          '''
        }
      }
    }
  }

  post {
    always {
      cleanWs()
      junit 'healthsync/backend/**/*.xml' allowEmptyResults: true
      archiveArtifacts artifacts: 'healthsync/backend/coverage/**', allowEmptyArchive: true
    }
    success {
      echo "✓ Pipeline completed successfully!"
    }
    failure {
      echo "✗ Pipeline failed. Check logs for details."
    }
  }
}
